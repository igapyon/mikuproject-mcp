{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://igapyon.github.io/mikuproject-mcp/contract/tools/mikuproject_export_workbook_json.input.schema.json",
  "title": "mikuproject_export_workbook_json input",
  "type": "object",
  "additionalProperties": false,
  "required": ["workbookPath"],
  "properties": {
    "workbookPath": {
      "type": "string",
      "minLength": 1,
      "description": "Path to the source mikuproject workbook JSON state passed to the upstream CLI as --in."
    },
    "outputPath": {
      "type": "string",
      "minLength": 1,
      "description": "Optional path for the exported workbook JSON artifact."
    }
  }
}
