{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://igapyon.github.io/mikuproject-mcp/contract/tools/mikuproject_ai_validate_patch.input.schema.json",
  "title": "mikuproject_ai_validate_patch input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "statePath"
  ],
  "properties": {
    "statePath": {
      "type": "string",
      "minLength": 1,
      "description": "Path to a mikuproject workbook JSON state passed to the upstream CLI as --state."
    },
    "patchPath": {
      "type": "string",
      "minLength": 1,
      "description": "Path to a mikuproject patch document passed to the upstream CLI as --in."
    },
    "patchContent": {
      "type": "string",
      "minLength": 1,
      "description": "Inline mikuproject patch JSON content passed to the upstream CLI on stdin with --in -."
    }
  },
  "oneOf": [
    {
      "required": [
        "patchPath"
      ],
      "not": {
        "required": [
          "patchContent"
        ]
      }
    },
    {
      "required": [
        "patchContent"
      ],
      "not": {
        "required": [
          "patchPath"
        ]
      }
    }
  ]
}
