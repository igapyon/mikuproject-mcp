{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://igapyon.github.io/mikuproject-mcp/contract/tools/mikuproject.ai_validate_patch.input.schema.json",
  "title": "mikuproject.ai_validate_patch input",
  "type": "object",
  "additionalProperties": false,
  "required": ["statePath", "patchPath"],
  "properties": {
    "statePath": {
      "type": "string",
      "minLength": 1,
      "description": "Path to a mikuproject workbook JSON state passed to the upstream CLI as --state."
    },
    "patchPath": {
      "type": "string",
      "minLength": 1,
      "description": "Path to a mikuproject patch document passed to the upstream CLI as --in."
    }
  }
}
