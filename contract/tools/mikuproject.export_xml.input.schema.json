{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://igapyon.github.io/mikuproject-mcp/contract/tools/mikuproject.export_xml.input.schema.json",
  "title": "mikuproject.export_xml input",
  "type": "object",
  "additionalProperties": false,
  "required": ["workbookPath"],
  "properties": {
    "workbookPath": {
      "type": "string",
      "minLength": 1,
      "description": "Path to the source mikuproject workbook JSON state passed to the upstream CLI as --in."
    },
    "outputPath": {
      "type": "string",
      "minLength": 1,
      "description": "Optional path for the exported MS Project XML artifact."
    }
  }
}
