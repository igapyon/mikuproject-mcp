{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://igapyon.github.io/mikuproject-mcp/contract/tools/mikuproject.ai_export_project_overview.input.schema.json",
  "title": "mikuproject.ai_export_project_overview input",
  "type": "object",
  "additionalProperties": false,
  "required": ["workbookPath"],
  "properties": {
    "workbookPath": {
      "type": "string",
      "minLength": 1,
      "description": "Path to a mikuproject workbook JSON file passed to the upstream CLI as --in."
    },
    "outputPath": {
      "type": "string",
      "minLength": 1,
      "description": "Optional path for the generated project_overview_view projection."
    }
  }
}
