{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://igapyon.github.io/mikuproject-mcp/contract/tools/mikuproject_ai_export_project_overview.input.schema.json",
  "title": "mikuproject_ai_export_project_overview input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "workbookPath": {
      "type": "string",
      "minLength": 1,
      "description": "Path to a mikuproject workbook JSON file passed to the upstream CLI as --in."
    },
    "outputPath": {
      "type": "string",
      "minLength": 1,
      "description": "Optional path for the generated project_overview_view projection."
    },
    "workbookContent": {
      "type": "string",
      "minLength": 1,
      "description": "Inline mikuproject workbook JSON content passed on stdin."
    },
    "outputMode": {
      "type": "string",
      "enum": [
        "path",
        "content"
      ],
      "description": "Output mode. Omit or use path to write an artifact path; use content to return text content directly."
    }
  },
  "allOf": [
    {
      "oneOf": [
        {
          "required": [
            "workbookPath"
          ],
          "not": {
            "required": [
              "workbookContent"
            ]
          }
        },
        {
          "required": [
            "workbookContent"
          ],
          "not": {
            "required": [
              "workbookPath"
            ]
          }
        }
      ]
    },
    {
      "not": {
        "required": [
          "outputPath",
          "outputMode"
        ],
        "properties": {
          "outputMode": {
            "const": "content"
          }
        }
      }
    }
  ]
}
