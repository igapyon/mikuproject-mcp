{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://igapyon.github.io/mikuproject-mcp/contract/tools/mikuproject_import_xlsx.input.schema.json",
  "title": "mikuproject_import_xlsx input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "inputPath": {
      "type": "string",
      "minLength": 1,
      "description": "Path to the source XLSX file passed to the upstream CLI as --in."
    },
    "inputBase64": {
      "type": "string",
      "minLength": 1,
      "description": "Base64-encoded XLSX content passed to the upstream CLI on stdin with --in-base64 -."
    },
    "outputPath": {
      "type": "string",
      "minLength": 1,
      "description": "Optional path for the imported workbook JSON state."
    },
    "outputMode": {
      "type": "string",
      "enum": [
        "path",
        "content"
      ],
      "description": "Output mode. Omit or use path to write an artifact path; use content to return text content directly."
    }
  },
  "allOf": [
    {
      "oneOf": [
        {
          "required": [
            "inputPath"
          ],
          "not": {
            "required": [
              "inputBase64"
            ]
          }
        },
        {
          "required": [
            "inputBase64"
          ],
          "not": {
            "required": [
              "inputPath"
            ]
          }
        }
      ]
    },
    {
      "not": {
        "required": [
          "outputPath",
          "outputMode"
        ],
        "properties": {
          "outputMode": {
            "const": "content"
          }
        }
      }
    }
  ]
}
